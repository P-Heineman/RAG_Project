    "rules": [
      {
        "id": "rule-001",
        "rule": "RAG Standards: שימוש ב-RecursiveCharacterTextSplitter עם chunk_size=500 ו-overlap=50. שימוש ב-sentence-transformers/all-MiniLM-L6-v2 להטמעות במהלך פיתוח מקומי. מניעת PII ב-vector store ושימוש ב-utils.mask_pii לפני אינדקס.",
        "scope": "rag",
        "source": {
          "tool": "Cursor",
          "file": "c:\\Users\\user1\\Desktop\\תכנות\\תשפו_בסד\\AI\\rag\\meta-observer-target\\.cursor\\rules.md"
        },
        "observed_at": "2026-05-03T21:13:43.751321"
      },
      {
        "id": "rule-002",
        "rule": "Backend (FastAPI): כל פעולות DB ו-Vector Store חייבות להיות Async. שימוש ב-Pydantic models לכל בקשות/תגובות API. אין להשתמש ב-generic Dicts.",
        "scope": "backend",
        "source": {
          "tool": "Cursor",
          "file": "c:\\Users\\user1\\Desktop\\תכנות\\תשפו_בסד\\AI\\rag\\meta-observer-target\\.cursor\\rules.md"
        },
        "observed_at": "2026-05-03T21:13:43.751321"
      },
      {
        "id": "rule-003",
        "rule": "Frontend (React): שימוש ב-Shadcn/UI (Radix UI) באופן בלעדי. שימוש ב-TanStack Query למצב שרת. ציון ציוני ביטחון בצבעים (ירוק > 0.8, צהוב > 0.5, אדום < 0.5).",
        "scope": "frontend",
        "source": {
          "tool": "Cursor",
          "file": "c:\\Users\\user1\\Desktop\\תכנות\\תשפו_בסד\\AI\\rag\\meta-observer-target\\.cursor\\rules.md"
        },
        "observed_at": "2026-05-03T21:13:43.751321"
      },
      {
        "id": "rule-004",
        "rule": "Audit Logging: שמירת רישום ב-backend/data/audit_log.json. חובה להסוות IPs ומפתחות API. שמירת רישומים ל-30 יום.",
        "scope": "audit",
        "source": {
          "tool": "Cursor",
          "file": "c:\\Users\\user1\\Desktop\\תכנות\\תשפו_בסד\\AI\\rag\\meta-observer-target\\.cursor\\rules.md"
        },
        "observed_at": "2026-05-03T21:13:43.751321"
      },
      {
        "id": "rule-005",
        "rule": "Resilience & Retries: עד 3 ניסיונות עם backoff אקספוננציאלי לכל קריאות AI/DB. מעבר למצב בטוח אם latency של Vector DB עולה על 5 שניות או status != 200. הפעלת Circuit Breaker לאחר 5 כשלונות רצופים.",
        "scope": "resilience",
        "source": {
          "tool": "Cursor",
          "file": "c:\\Users\\user1\\Desktop\\תכנות\\תשפו_בסד\\AI\\rag\\meta-observer-target\\.cursor\\rules.md"
